<Window
    x:Class="Cbdb.App.Avalonia.AboutWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="560"
    Height="360"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    Background="#F6F6F6">
  <Border Padding="20" Background="#F6F6F6">
    <Grid RowDefinitions="Auto,*,Auto">
      <TextBlock x:Name="TxtTitle"
                 Grid.Row="0"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="#133FB5"
                 Text="CBDB Desktop" />

      <ScrollViewer Grid.Row="1"
                    Margin="0,16,0,16"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14">
          <TextBlock x:Name="TxtBody"
                     TextWrapping="Wrap"
                     FontSize="15"
                     LineHeight="24" />

          <Border Background="#FFFFFF"
                  BorderBrush="#D6D6D6"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14">
            <StackPanel Spacing="8">
              <TextBlock Text="Temporary Font Test"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#133FB5" />
              <TextBlock x:Name="TxtFontDebug"
                         FontSize="12"
                         Foreground="#555555"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="TxtFontSample"
                         FontSize="18"
                         LineHeight="28"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Button x:Name="BtnClose"
              Grid.Row="2"
              HorizontalAlignment="Center"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              Width="96"
              Height="34"
              Click="BtnClose_Click" />
    </Grid>
  </Border>
</Window>
