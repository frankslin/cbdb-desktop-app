<Window
    x:Class="Cbdb.App.Avalonia.AboutWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="560"
    Height="380"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    Background="#F6F6F6">
  <Window.Styles>
    <Style Selector="Button.link-button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="#133FB5" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.link-button:pointerover /template/ ContentPresenter">
      <Setter Property="TextBlock.TextDecorations" Value="Underline" />
    </Style>
    <Style Selector="Button.link-button:disabled">
      <Setter Property="Foreground" Value="#808080" />
    </Style>
  </Window.Styles>
  <Border Padding="20" Background="#F6F6F6">
    <Grid RowDefinitions="Auto,*,Auto">
      <TextBlock x:Name="TxtTitle"
                 Grid.Row="0"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="#133FB5"
                 Text="CBDB Desktop" />

      <ScrollViewer Grid.Row="1"
                    Margin="0,16,0,16"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14">
          <TextBlock x:Name="TxtBody"
                     TextWrapping="Wrap"
                     FontSize="15"
                     LineHeight="24" />

          <Border Background="#FFFFFF"
                  BorderBrush="#D6D6D6"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14">
            <StackPanel Spacing="10">
              <TextBlock x:Name="TxtUpdateStatus"
                         FontSize="13"
                         Foreground="#333333"
                         TextWrapping="Wrap" />
              <StackPanel Orientation="Horizontal"
                          Spacing="14">
                <Button x:Name="BtnCheckUpdates"
                        Classes="link-button"
                        HorizontalAlignment="Left"
                        Click="BtnCheckUpdates_Click" />
                <Button x:Name="BtnOpenLatestRelease"
                        Classes="link-button"
                        HorizontalAlignment="Left"
                        Click="BtnOpenLatestRelease_Click" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Button x:Name="BtnClose"
              Grid.Row="2"
              HorizontalAlignment="Center"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              Width="96"
              Height="34"
              Click="BtnClose_Click" />
    </Grid>
  </Border>
</Window>
