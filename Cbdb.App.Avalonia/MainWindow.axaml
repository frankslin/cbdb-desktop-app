<Window
    x:Class="Cbdb.App.Avalonia.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NAVIGATION_PANE"
    Icon="/Assets/AppIcon.png"
    Width="1000"
    Height="780"
    MinWidth="920"
    MinHeight="680"
    Background="#F2F2F2">
  <Window.Styles>
    <Style Selector="Button.module-tile">
      <Setter Property="Height" Value="74" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="Background" Value="#F4F4F4" />
      <Setter Property="BorderBrush" Value="#8E8E8E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.side-action">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton.language-toggle">
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0,2" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#F4F4F4" />
      <Setter Property="BorderBrush" Value="#8E8E8E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="ToggleButton.language-toggle:checked">
      <Setter Property="Background" Value="#133FB5" />
      <Setter Property="BorderBrush" Value="#133FB5" />
      <Setter Property="Foreground" Value="White" />
    </Style>
  </Window.Styles>
  <Grid Margin="14" ColumnDefinitions="*,200" RowDefinitions="Auto,*,Auto">
    <Grid Grid.ColumnSpan="2" ColumnDefinitions="*,Auto">
      <Border Grid.Column="0"
              HorizontalAlignment="Center"
              Background="#133FB5"
              Padding="16,4">
        <TextBlock x:Name="TxtHeaderMain"
                   FontSize="34"
                   Foreground="White"
                   Text="中國歷代人物傳記資料庫" />
      </Border>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top">
        <ToggleButton x:Name="BtnLangEn" Classes="language-toggle" Margin="4,0,0,0" Click="BtnLangEn_Click" Content="EN" />
        <ToggleButton x:Name="BtnLangZhHant" Classes="language-toggle" Margin="4,0,0,0" Click="BtnLangZhHant_Click" Content="繁" />
        <ToggleButton x:Name="BtnLangZhHans" Classes="language-toggle" Margin="4,0,0,0" Click="BtnLangZhHans_Click" Content="简" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="1"
            Grid.Column="0"
            Margin="4,12,14,0"
            Padding="20,16"
            BorderBrush="Black"
            BorderThickness="1"
            Background="#F9F9F9">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <Button x:Name="BtnModuleBrowser" Classes="module-tile" Grid.Row="0" Grid.Column="0" Margin="0,0,12,12" Click="ModuleButton_Click" Tag="module.browser" />
          <Button x:Name="BtnModuleEntry" Classes="module-tile" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12" Click="ModuleButton_Click" Tag="module.entry" />
          <Button x:Name="BtnModuleOffice" Classes="module-tile" Grid.Row="1" Grid.Column="0" Margin="0,0,12,12" Click="ModuleButton_Click" Tag="module.office" />
          <Button x:Name="BtnModuleKinship" Classes="module-tile" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" Click="ModuleButton_Click" Tag="module.kinship" />
          <Button x:Name="BtnModuleAssociations" Classes="module-tile" Grid.Row="2" Grid.Column="0" Margin="0,0,12,12" Click="ModuleButton_Click" Tag="module.associations" />
          <Button x:Name="BtnModuleNetworks" Classes="module-tile" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" Click="ModuleButton_Click" Tag="module.networks" />
          <Button x:Name="BtnModuleAssociationPairs" Classes="module-tile" Grid.Row="3" Grid.Column="0" Margin="0,0,12,12" Click="ModuleButton_Click" Tag="module.association_pairs" />
          <Button x:Name="BtnModulePlace" Classes="module-tile" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" Click="ModuleButton_Click" Tag="module.place" />
          <Button x:Name="BtnModuleStatus" Classes="module-tile" Grid.Row="4" Grid.Column="0" Margin="0,0,12,0" Click="ModuleButton_Click" Tag="module.status" />
          <Button x:Name="BtnModuleTexts" Classes="module-tile" Grid.Row="4" Grid.Column="1" Click="ModuleButton_Click" Tag="module.texts" />
        </Grid>
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="1"
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Margin="0,0,0,10">
      <Button x:Name="BtnReportError" Classes="side-action" Height="46" Margin="0,0,0,10" Click="BtnReportError_Click" />
      <Button x:Name="BtnRelinkTables" Classes="side-action" Height="46" Margin="0,0,0,10" Click="BtnRelinkTables_Click" />
      <Button x:Name="BtnDownloadLatestData" Classes="side-action" Height="46" Margin="0,0,0,10" Click="BtnDownloadLatestData_Click" />
      <Button x:Name="BtnChangeIndexAddress" Classes="side-action" Height="46" Margin="0,0,0,10" Click="BtnChangeIndexAddress_Click" />
      <Button x:Name="BtnUsersGuide" Classes="side-action" Height="46" Margin="0,0,0,10" Click="BtnUsersGuide_Click" />
      <Button x:Name="BtnAbout" Classes="side-action" Height="46" Margin="0,0,0,10" Click="BtnAbout_Click" />
      <Button x:Name="BtnExit" Classes="side-action" Height="36" Click="BtnExit_Click" />
    </StackPanel>

    <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="0,12,0,0"
            Padding="8"
            BorderBrush="#D0D0D0"
            BorderThickness="1"
            Background="White">
      <StackPanel>
        <TextBlock x:Name="TxtStatus" FontWeight="SemiBold" Text="Ready" />
        <TextBox x:Name="TxtOutput"
                 Margin="0,6,0,0"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 MinHeight="86"
                 MaxHeight="120" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
