<Window
    x:Class="Cbdb.App.Avalonia.Browser.PersonBrowserWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:Cbdb.App.Core;assembly=Cbdb.App.Core"
    Title="Person Browser"
    Width="1380"
    Height="820"
    MinWidth="1180"
    MinHeight="720"
    Background="#DCDCDC">
  <Window.Styles>
    <Style Selector="TabControl">
      <Setter Property="Background" Value="#E9E9E9" />
    </Style>

    <Style Selector="TabControl > TabItem">
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Margin" Value="0,0,2,0" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Background" Value="#D7D7D7" />
      <Setter Property="BorderBrush" Value="#9F9F9F" />
      <Setter Property="BorderThickness" Value="1,1,1,0" />
      <Setter Property="Foreground" Value="#222222" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TabControl > TabItem:pointerover">
      <Setter Property="Background" Value="#E5E5E5" />
    </Style>

    <Style Selector="TabControl > TabItem:selected">
      <Setter Property="Background" Value="#F7F7F7" />
      <Setter Property="BorderBrush" Value="#868686" />
      <Setter Property="Foreground" Value="#000000" />
    </Style>

    <Style Selector="TabControl > ContentPresenter#PART_SelectedContentHost">
      <Setter Property="Background" Value="#F7F7F7" />
      <Setter Property="BorderBrush" Value="#868686" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10" />
    </Style>
  </Window.Styles>
  <Grid Margin="8" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="36,36,*,92,92">
        <Button x:Name="BtnHistoryBack"
                Grid.Column="0"
                Width="32"
                Height="30"
                Margin="0,0,6,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="BtnHistoryBack_Click"
                Content="←" />
        <Button x:Name="BtnHistoryForward"
                Grid.Column="1"
                Width="32"
                Height="30"
                Margin="0,0,8,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="BtnHistoryForward_Click"
                Content="→" />
        <TextBox x:Name="TxtKeyword"
                 Grid.Column="2"
                 Height="30"
                 Margin="0,0,8,0"
                 VerticalContentAlignment="Center"
                 KeyDown="TxtKeyword_KeyDown" />
        <Button x:Name="BtnSearch" Grid.Column="3" Height="30" Margin="0,0,8,0" Click="BtnSearch_Click" />
        <Button x:Name="BtnClear" Grid.Column="4" Height="30" Click="BtnClear_Click" />
    </Grid>

    <Grid Grid.Row="1" Margin="0,8,0,0" ColumnDefinitions="4*,6,7*">
      <Border Grid.Column="0"
              BorderBrush="#A9A9A9"
              BorderThickness="1"
              Background="#F3F3F3"
              Padding="4"
              Margin="0,0,6,0">
        <Grid RowDefinitions="Auto,*,Auto">
          <DataGrid x:Name="GridPeople"
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"
                    LoadingRow="GridPeople_LoadingRow"
                    SelectionMode="Single"
                    SelectionChanged="GridPeople_SelectionChanged"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
              <DataGridTextColumn Binding="{Binding PersonId}" Width="70" />
              <DataGridTextColumn Binding="{Binding NameChn}" Width="140" />
              <DataGridTextColumn Binding="{Binding NameRm}" Width="160" />
              <DataGridTextColumn Binding="{Binding IndexYear}" Width="100" />
              <DataGridTextColumn Binding="{Binding IndexAddress}" Width="260" />
            </DataGrid.Columns>
          </DataGrid>

          <Grid Grid.Row="2" Margin="2,6,2,2" ColumnDefinitions="*,Auto">
            <TextBlock x:Name="TxtRecord" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#333" />
            <Button x:Name="BtnSaveToFile" Grid.Column="1" Height="32" MinWidth="98" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="BtnSaveToFile_Click" />
          </Grid>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1"
                    Width="6"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    Background="#D0D0D0" />

      <Border Grid.Column="2"
              BorderBrush="#A9A9A9"
              BorderThickness="1"
              Background="#E9E9E9"
              Padding="6">
        <Grid RowDefinitions="Auto,*">
          <Border BorderBrush="#C7C7C7" BorderThickness="1" Background="#F7F7F7" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <Grid ColumnDefinitions="Auto,1.15*,Auto,1.15*,Auto,1.2*,Auto,0.9*">
                <TextBlock x:Name="LblSurnameChnField" Grid.Column="0" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValSurnameChn" Grid.Column="1" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                <TextBlock x:Name="LblMingziChnField" Grid.Column="2" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValMingziChn" Grid.Column="3" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                <TextBlock x:Name="LblNameChnField" Grid.Column="4" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValNameChn" Grid.Column="5" Height="24" Margin="6,0,10,0" MinWidth="100" IsReadOnly="True" />
                <TextBlock x:Name="LblPersonId" Grid.Column="6" VerticalAlignment="Center" Foreground="Blue" />
                <TextBox x:Name="ValPersonId" Grid.Column="7" Height="24" Margin="6,0,0,0" MinWidth="70" IsReadOnly="True" />
              </Grid>

              <Grid Grid.Row="1" Margin="0,6,0,0" ColumnDefinitions="Auto,1.15*,Auto,1.15*,Auto,1.2*,Auto,0.9*">
                <TextBlock x:Name="LblSurnameField" Grid.Column="0" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValSurname" Grid.Column="1" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                <TextBlock x:Name="LblMingziField" Grid.Column="2" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValMingzi" Grid.Column="3" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                <TextBlock x:Name="LblNameField" Grid.Column="4" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValName" Grid.Column="5" Height="24" Margin="6,0,10,0" MinWidth="100" IsReadOnly="True" />
                <TextBlock x:Name="LblGenderSummary" Grid.Column="6" VerticalAlignment="Center" Foreground="Blue" />
                <TextBox x:Name="ValGender" Grid.Column="7" Height="24" Margin="6,0,0,0" MinWidth="80" IsReadOnly="True" />
              </Grid>

              <Grid Grid.Row="2" Margin="0,6,0,0" ColumnDefinitions="Auto,1.15*,Auto,1.15*,Auto,1.2*,Auto,0.9*">
                <TextBlock x:Name="LblSurnameProperField" Grid.Column="0" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValSurnameProper" Grid.Column="1" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                <TextBlock x:Name="LblMingziProperField" Grid.Column="2" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValMingziProper" Grid.Column="3" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                <TextBlock x:Name="LblNameProperField" Grid.Column="4" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValNameProper" Grid.Column="5" Height="24" Margin="6,0,10,0" MinWidth="100" IsReadOnly="True" />
                <TextBlock x:Name="LblBirthYearSummary" Grid.Column="6" VerticalAlignment="Center" Foreground="Blue" />
                <TextBox x:Name="ValBirthYear" Grid.Column="7" Height="24" Margin="6,0,0,0" MinWidth="70" IsReadOnly="True" />
              </Grid>

              <Grid Grid.Row="3" Margin="0,6,0,0" ColumnDefinitions="Auto,1.15*,Auto,1.15*,Auto,1.2*,Auto,0.9*">
                <TextBlock x:Name="LblSurnameRmField" Grid.Column="0" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValSurnameRm" Grid.Column="1" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                <TextBlock x:Name="LblMingziRmField" Grid.Column="2" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValMingziRm" Grid.Column="3" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                <TextBlock x:Name="LblNameRmField" Grid.Column="4" VerticalAlignment="Center" Foreground="Red" />
                <TextBox x:Name="ValNameRm" Grid.Column="5" Height="24" Margin="6,0,10,0" MinWidth="100" IsReadOnly="True" />
                <TextBlock x:Name="LblDeathYearSummary" Grid.Column="6" VerticalAlignment="Center" Foreground="Blue" />
                <TextBox x:Name="ValDeathYear" Grid.Column="7" Height="24" Margin="6,0,0,0" MinWidth="90" IsReadOnly="True" />
              </Grid>

              <Grid Grid.Row="4" Margin="0,8,0,0" ColumnDefinitions="Auto,*">
                <TextBlock x:Name="LblDynastySummary" Grid.Column="0" VerticalAlignment="Center" />
                <TextBox x:Name="ValDynasty" Grid.Column="1" Height="24" Margin="6,0,0,0" IsReadOnly="True" />
              </Grid>

              <Grid Grid.Row="5" Margin="0,6,0,0" ColumnDefinitions="Auto,0.8*,Auto,1.1*,Auto,1.4*">
                <TextBlock x:Name="LblIndexYearSummary" Grid.Column="0" VerticalAlignment="Center" />
                <TextBox x:Name="ValIndexYear" Grid.Column="1" Height="24" Margin="6,0,10,0" IsReadOnly="True" />
                <TextBlock x:Name="LblIndexYearTypeSummary" Grid.Column="2" VerticalAlignment="Center" />
                <TextBox x:Name="ValIndexYearType" Grid.Column="3" Height="24" Margin="6,0,10,0" IsReadOnly="True" />
                <TextBlock x:Name="LblIndexYearSourceSummary" Grid.Column="4" VerticalAlignment="Center" />
                <TextBox x:Name="ValIndexYearSource" Grid.Column="5" Height="24" Margin="6,0,0,0" IsReadOnly="True" />
              </Grid>

              <Grid Grid.Row="6" Margin="0,6,0,0" ColumnDefinitions="Auto,1.5*,Auto,1*">
                <TextBlock x:Name="LblIndexAddressSummary" Grid.Column="0" VerticalAlignment="Center" />
                <TextBox x:Name="ValIndexAddress" Grid.Column="1" Height="24" Margin="6,0,10,0" IsReadOnly="True" />
                <TextBlock x:Name="LblIndexAddressTypeSummary" Grid.Column="2" VerticalAlignment="Center" />
                <TextBox x:Name="ValIndexAddressType" Grid.Column="3" Height="24" Margin="6,0,0,0" IsReadOnly="True" />
              </Grid>
            </Grid>
          </Border>

          <TabControl x:Name="MainTabs" Grid.Row="1" Margin="0,8,0,0" SelectionChanged="MainTabs_SelectionChanged">
            <TabItem x:Name="TabBasic">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,4,8,8">
                  <TextBlock x:Name="TxtNoSelection" Margin="0,0,0,8" Foreground="#666" IsVisible="False" />
                  <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="HdrBasic_birth_group" FontWeight="Bold" Margin="0,0,0,6" />
                    <Border BorderBrush="#CFCFCF" BorderThickness="1" Background="#FAFAFA" Padding="8">
                    <Grid ColumnDefinitions="Auto,180,Auto,180,Auto,*" RowDefinitions="Auto,Auto,Auto">
                      <TextBlock x:Name="LblBasic_birth_gregorian" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_birth_year" Grid.Row="0" Grid.Column="1" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_birth_nianhao" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_birth_nianhao" Grid.Row="0" Grid.Column="3" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_birth_nianhao_year" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_birth_nianhao_year" Grid.Row="0" Grid.Column="5" Margin="0,0,0,6" IsReadOnly="True" />

                      <TextBlock x:Name="LblBasic_birth_month" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_birth_month" Grid.Row="1" Grid.Column="1" Margin="0,0,12,6" IsReadOnly="True" />
                      <CheckBox x:Name="ChkBasic_birth_intercalary" Grid.Row="1" Grid.Column="3" Margin="0,0,12,6" IsEnabled="False" />
                      <TextBlock x:Name="LblBasic_birth_day" Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_birth_day" Grid.Row="1" Grid.Column="5" Margin="0,0,0,6" IsReadOnly="True" />

                      <TextBlock x:Name="LblBasic_birth_ganzhi" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_birth_ganzhi" Grid.Row="2" Grid.Column="1" Margin="0,0,12,0" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_birth_range" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_birth_range" Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="3" IsReadOnly="True" />
                    </Grid>
                    </Border>
                  </StackPanel>

                  <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="HdrBasic_death_group" FontWeight="Bold" Margin="0,0,0,6" />
                    <Border BorderBrush="#CFCFCF" BorderThickness="1" Background="#FAFAFA" Padding="8">
                    <Grid ColumnDefinitions="Auto,180,Auto,180,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                      <TextBlock x:Name="LblBasic_death_gregorian" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_death_year" Grid.Row="0" Grid.Column="1" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_death_nianhao" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_death_nianhao" Grid.Row="0" Grid.Column="3" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_death_nianhao_year" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_death_nianhao_year" Grid.Row="0" Grid.Column="5" Margin="0,0,0,6" IsReadOnly="True" />

                      <TextBlock x:Name="LblBasic_death_month" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_death_month" Grid.Row="1" Grid.Column="1" Margin="0,0,12,6" IsReadOnly="True" />
                      <CheckBox x:Name="ChkBasic_death_intercalary" Grid.Row="1" Grid.Column="3" Margin="0,0,12,6" IsEnabled="False" />
                      <TextBlock x:Name="LblBasic_death_day" Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_death_day" Grid.Row="1" Grid.Column="5" Margin="0,0,0,6" IsReadOnly="True" />

                      <TextBlock x:Name="LblBasic_death_ganzhi" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_death_ganzhi" Grid.Row="2" Grid.Column="1" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_death_range" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_death_range" Grid.Row="2" Grid.Column="3" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_death_age" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_death_age" Grid.Row="3" Grid.Column="1" Margin="0,0,12,0" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_death_age_range" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_death_age_range" Grid.Row="3" Grid.Column="3" IsReadOnly="True" />
                    </Grid>
                    </Border>
                  </StackPanel>

                  <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="HdrBasic_fl_group" FontWeight="Bold" Margin="0,0,0,6" />
                    <Border BorderBrush="#CFCFCF" BorderThickness="1" Background="#FAFAFA" Padding="8">
                    <Grid ColumnDefinitions="Auto,120,Auto,220,Auto,100,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                      <TextBlock x:Name="LblBasic_fl_first_year" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_fl_first_year" Grid.Row="0" Grid.Column="1" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_fl_first_nianhao" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_fl_first_nianhao" Grid.Row="0" Grid.Column="3" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_fl_first_nianhao_year" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_fl_first_nianhao_year" Grid.Row="0" Grid.Column="5" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_fl_first_notes" Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" />
                      <TextBox x:Name="ValBasic_fl_first_notes" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="7" Margin="0,0,0,6" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="44" />

                      <TextBlock x:Name="LblBasic_fl_last_year" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_fl_last_year" Grid.Row="2" Grid.Column="1" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_fl_last_nianhao" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_fl_last_nianhao" Grid.Row="2" Grid.Column="3" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_fl_last_nianhao_year" Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_fl_last_nianhao_year" Grid.Row="2" Grid.Column="5" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_fl_last_notes" Grid.Row="3" Grid.Column="0" VerticalAlignment="Top" />
                      <TextBox x:Name="ValBasic_fl_last_notes" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="7" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="44" />
                    </Grid>
                    </Border>
                  </StackPanel>

                  <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="HdrBasic_identity_group" FontWeight="Bold" Margin="0,0,0,6" />
                    <Border BorderBrush="#CFCFCF" BorderThickness="1" Background="#FAFAFA" Padding="8">
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                      <TextBlock x:Name="LblBasic_choronym" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_choronym" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_household" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_household" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_ethnicity_tribe" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_ethnicity_tribe" Grid.Row="2" Grid.Column="1" IsReadOnly="True" />
                    </Grid>
                    </Border>
                  </StackPanel>

                  <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="HdrBasic_notes_group" FontWeight="Bold" Margin="0,0,0,6" />
                    <Border BorderBrush="#CFCFCF" BorderThickness="1" Background="#FAFAFA" Padding="8">
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock x:Name="LblBasic_notes" Grid.Column="0" VerticalAlignment="Top" />
                      <TextBox x:Name="ValBasic_notes" Grid.Column="1" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="70" />
                    </Grid>
                    </Border>
                  </StackPanel>

                  <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="HdrBasic_audit_group" FontWeight="Bold" Margin="0,0,0,6" />
                    <Border BorderBrush="#CFCFCF" BorderThickness="1" Background="#FAFAFA" Padding="8">
                    <Grid ColumnDefinitions="Auto,160,Auto,180" RowDefinitions="Auto,Auto">
                      <TextBlock x:Name="LblBasic_created_by" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_created_by" Grid.Row="0" Grid.Column="1" Margin="0,0,12,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_created_date" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_created_date" Grid.Row="0" Grid.Column="3" Margin="0,0,0,6" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_modified_by" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_modified_by" Grid.Row="1" Grid.Column="1" Margin="0,0,12,0" IsReadOnly="True" />
                      <TextBlock x:Name="LblBasic_modified_date" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" />
                      <TextBox x:Name="ValBasic_modified_date" Grid.Row="1" Grid.Column="3" IsReadOnly="True" />
                    </Grid>
                    </Border>
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </TabItem>

            <TabItem x:Name="TabAddresses">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,4,8,8" Spacing="8">
                  <Border x:Name="AddressesLoadingHost" IsVisible="False" Background="#F7F7F7" BorderBrush="#D9D9D9" BorderThickness="1" Padding="12">
                    <StackPanel Spacing="8">
                      <TextBlock x:Name="TxtAddressesLoading" Foreground="#666" />
                      <ProgressBar IsIndeterminate="True" Height="6" />
                    </StackPanel>
                  </Border>
                  <TextBlock x:Name="TxtAddressesEmpty" Foreground="#666" TextWrapping="Wrap" />
                  <StackPanel x:Name="AddressesPanel" Spacing="8" />
                  <StackPanel x:Name="AddressesPager" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button x:Name="BtnAddressesPrev" Tag="addresses" Click="TabPrevPage_Click" />
                    <TextBlock x:Name="TxtAddressesPage" VerticalAlignment="Center" />
                    <Button x:Name="BtnAddressesNext" Tag="addresses" Click="TabNextPage_Click" />
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
            <TabItem x:Name="TabAltNames">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,4,8,8" Spacing="8">
                  <Border x:Name="AltNamesLoadingHost" IsVisible="False" Background="#F7F7F7" BorderBrush="#D9D9D9" BorderThickness="1" Padding="12">
                    <StackPanel Spacing="8">
                      <TextBlock x:Name="TxtAltNamesLoading" Foreground="#666" />
                      <ProgressBar IsIndeterminate="True" Height="6" />
                    </StackPanel>
                  </Border>
                  <TextBlock x:Name="TxtAltNamesEmpty" Foreground="#666" TextWrapping="Wrap" />
                  <StackPanel x:Name="AltNamesPanel" Spacing="8" />
                  <StackPanel x:Name="AltNamesPager" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button x:Name="BtnAltNamesPrev" Tag="alt_names" Click="TabPrevPage_Click" />
                    <TextBlock x:Name="TxtAltNamesPage" VerticalAlignment="Center" />
                    <Button x:Name="BtnAltNamesNext" Tag="alt_names" Click="TabNextPage_Click" />
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
            <TabItem x:Name="TabWritings">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,4,8,8" Spacing="8">
                  <Border x:Name="WritingsLoadingHost" IsVisible="False" Background="#F7F7F7" BorderBrush="#D9D9D9" BorderThickness="1" Padding="12">
