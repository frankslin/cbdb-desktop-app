<Window
    x:Class="Cbdb.App.Avalonia.Modules.PlacePickerWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Select Place"
    Width="780"
    Height="620"
    MinWidth="620"
    MinHeight="460"
    Background="#E5E5E5">
  <Window.Styles>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,4" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <Grid Margin="10" RowDefinitions="Auto,*,Auto">
    <Border BorderBrush="#B9B9B9" BorderThickness="1" Background="#F4F4F4" Padding="10">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBox x:Name="TxtSearch" KeyDown="TxtSearch_KeyDown" />
        <Button x:Name="BtnRunSearch" Grid.Column="1" Margin="8,0,0,0" Click="BtnRunSearch_Click" />
        <Button x:Name="BtnClearSearch" Grid.Column="2" Margin="8,0,0,0" Click="BtnClearSearch_Click" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Margin="0,8,0,8" BorderBrush="#B9B9B9" BorderThickness="1" Background="#FAFAFA" Padding="10">
      <Grid RowDefinitions="Auto,*">
        <TextBlock x:Name="TxtSummary" Foreground="#444" />
        <ScrollViewer Grid.Row="1" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
          <ItemsControl x:Name="PlaceOptionHost">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border
                    Background="Transparent"
                    BorderBrush="LightGray"
                    BorderThickness="0,0,0,1"
                    Padding="4,3"
                    Cursor="Hand"
                    PointerReleased="PlaceOptionRow_PointerReleased">
                  <Grid ColumnDefinitions="Auto,*">
                    <CheckBox
                        IsChecked="{Binding IsSelected}"
                        VerticalAlignment="Top"
                        IsHitTestVisible="False"
                        Focusable="False" />
                    <StackPanel Grid.Column="1" Spacing="2">
                      <TextBlock Text="{Binding DisplayLabel}" />
                      <TextBlock
                          Text="{Binding DetailLabel}"
                          Foreground="DimGray"
                          FontSize="{DynamicResource AppSmallFontSize}"
                          IsVisible="{Binding HasDetailLabel}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="2" BorderBrush="#B9B9B9" BorderThickness="1" Background="#F4F4F4" Padding="10">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
        <Button x:Name="BtnSelectVisible" Click="BtnSelectVisible_Click" />
        <Button x:Name="BtnInvertVisible" Grid.Column="1" Margin="8,0,0,0" Click="BtnInvertVisible_Click" />
        <Button x:Name="BtnClearAll" Grid.Column="3" Margin="8,0,0,0" Click="BtnClearAll_Click" />
        <Button x:Name="BtnCancel" Grid.Column="4" Margin="8,0,0,0" Click="BtnCancel_Click" />
        <Button x:Name="BtnApply" Grid.Column="5" Margin="8,0,0,0" Click="BtnApply_Click" />
      </Grid>
    </Border>
  </Grid>
</Window>
