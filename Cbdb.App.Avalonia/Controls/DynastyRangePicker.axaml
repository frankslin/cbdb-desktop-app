<UserControl
    x:Class="Cbdb.App.Avalonia.Controls.DynastyRangePicker"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid ColumnDefinitions="Auto,420,Auto" RowDefinitions="Auto">
    <Button x:Name="BtnSelectDynasties" Margin="0,0,8,0" />
    <TextBox x:Name="TxtSelectedDynasties" Grid.Column="1" Margin="0,0,8,0" IsReadOnly="True" />
    <Button x:Name="BtnClearDynasties" Grid.Column="2" />
  </Grid>
</UserControl>
