<Window x:Class="Cbdb.App.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NAVIGATION_PANE"
        Height="780"
        Width="1000"
        MinHeight="680"
        MinWidth="920"
        Background="#F2F2F2">
    <Window.Resources>
        <Style x:Key="ModuleTileButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="74" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Background" Value="#F4F4F4" />
            <Setter Property="BorderBrush" Value="#8E8E8E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>

        <Grid Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    HorizontalAlignment="Center"
                    Background="#133FB5"
                    Padding="16,4">
                <TextBlock Name="TxtHeaderMain"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="White"
                           Text="中國歷代人物傳記資料庫" />
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Name="BtnLangEn" Width="40" Height="28" Margin="4,0,0,0" Click="BtnLangEn_Click" Content="EN" />
                <Button Name="BtnLangZhHant" Width="40" Height="28" Margin="4,0,0,0" Click="BtnLangZhHant_Click" Content="繁" />
                <Button Name="BtnLangZhHans" Width="40" Height="28" Margin="4,0,0,0" Click="BtnLangZhHans_Click" Content="简" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="4,12,14,0"
                Padding="20,16"
                BorderBrush="Black"
                BorderThickness="1"
                Background="#F9F9F9">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <UniformGrid Columns="2">
                    <Button Name="BtnModuleBrowser" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.browser" />
                    <Button Name="BtnModuleEntry" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.entry" />
                    <Button Name="BtnModuleOffice" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.office" />
                    <Button Name="BtnModuleKinship" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.kinship" />
                    <Button Name="BtnModuleAssociations" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.associations" />
                    <Button Name="BtnModuleNetworks" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.networks" />
                    <Button Name="BtnModuleAssociationPairs" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.association_pairs" />
                    <Button Name="BtnModulePlace" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.place" />
                    <Button Name="BtnModuleStatus" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.status" />
                    <Button Name="BtnModuleTexts" Style="{StaticResource ModuleTileButtonStyle}" Click="ModuleButton_Click" Tag="module.texts" />
                </UniformGrid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,10">
            <Button Name="BtnReportError" Height="46" Margin="0,0,0,10" Click="BtnReportError_Click" />
            <Button Name="BtnRelinkTables" Height="46" Margin="0,0,0,10" Click="BtnRelinkTables_Click" />
            <Button Name="BtnChangeIndexAddress" Height="46" Margin="0,0,0,10" Click="BtnChangeIndexAddress_Click" />
            <Button Name="BtnUsersGuide" Height="46" Margin="0,0,0,10" Click="BtnUsersGuide_Click" />
            <Button Name="BtnExit" Height="36" Click="BtnExit_Click" />
        </StackPanel>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="0,12,0,0"
                Padding="8"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                Background="White">
            <StackPanel>
                <TextBlock Name="TxtStatus" FontWeight="SemiBold" Text="Ready" />
                <TextBox Name="TxtOutput"
                         Margin="0,6,0,0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         MinHeight="86"
                         MaxHeight="120" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
