<Window x:Class="Cbdb.App.Desktop.Browser.PersonBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CBDB Browser"
        Height="820"
        Width="1380"
        MinHeight="720"
        MinWidth="1180"
        Background="#DCDCDC">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="92" />
                </Grid.ColumnDefinitions>

                <TextBox Name="TxtKeyword"
                         Grid.Column="0"
                         Height="30"
                         Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         KeyDown="TxtKeyword_KeyDown" />
                <Button Name="BtnSearch" Grid.Column="1" Height="30" Margin="0,0,8,0" Click="BtnSearch_Click" Content="Search" />
                <Button Name="BtnClear" Grid.Column="2" Height="30" Click="BtnClear_Click" Content="Clear" />
            </Grid>
            <TextBlock Name="LblSearchByName" Margin="2,6,0,0" Foreground="#444" FontWeight="SemiBold" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#A9A9A9" BorderThickness="1" Background="#F3F3F3" Padding="4" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid Name="GridPeople"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="GridPeople_SelectionChanged"
                              LoadingRow="GridPeople_LoadingRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Vertical"
                              CanUserResizeRows="False"
                              CanUserAddRows="False"
                              Margin="0" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ColPersonId" Header="ID" Binding="{Binding PersonId}" Width="70" />
                            <DataGridTextColumn x:Name="ColNameChn" Header="Chinese Name" Binding="{Binding NameChn}" Width="120" />
                            <DataGridTextColumn x:Name="ColNameRm" Header="Pinyin Name" Binding="{Binding NameRm}" Width="130" />
                            <DataGridTextColumn x:Name="ColIndexYear" Header="Index Year" Binding="{Binding IndexYear}" Width="85" />
                            <DataGridTextColumn x:Name="ColIndexAddress" Header="Index Address" Binding="{Binding IndexAddress}" Width="220" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="1" Name="TxtRecord" Margin="2,6,2,4" Foreground="#333" />

                    <StackPanel Grid.Row="2">
                        <Button Name="BtnSaveToFile" Height="28" Click="BtnSaveToFile_Click" Content="Save to File" />
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Background="#D0D0D0"
                          ShowsPreview="True" />

            <Border Grid.Column="2" BorderBrush="#A9A9A9" BorderThickness="1" Background="#E9E9E9" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border BorderBrush="#C7C7C7" BorderThickness="1" Background="#F7F7F7" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="LblSurnameChnField" Grid.Column="0" VerticalAlignment="Center" Foreground="Red" Text="c_surname_chn" />
                                <TextBox Name="ValSurnameChn" Grid.Column="1" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                                <TextBlock Name="LblMingziChnField" Grid.Column="2" VerticalAlignment="Center" Foreground="Red" Text="c_mingzi_chn" />
                                <TextBox Name="ValMingziChn" Grid.Column="3" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                                <TextBlock Name="LblNameChnField" Grid.Column="4" VerticalAlignment="Center" Foreground="Red" Text="c_name_chn" />
                                <TextBox Name="ValNameChn" Grid.Column="5" Height="24" Margin="6,0,10,0" MinWidth="100" IsReadOnly="True" />
                                <TextBlock Grid.Column="6" VerticalAlignment="Center" Foreground="Blue" Text="c_personid" />
                                <TextBox Name="ValPersonId" Grid.Column="7" Height="24" Margin="6,0,0,0" MinWidth="70" IsReadOnly="True" />
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="LblSurnameField" Grid.Column="0" VerticalAlignment="Center" Foreground="Red" Text="c_surname" />
                                <TextBox Name="ValSurname" Grid.Column="1" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                                <TextBlock Name="LblMingziField" Grid.Column="2" VerticalAlignment="Center" Foreground="Red" Text="c_mingzi" />
                                <TextBox Name="ValMingzi" Grid.Column="3" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                                <TextBlock Name="LblNameField" Grid.Column="4" VerticalAlignment="Center" Foreground="Red" Text="c_name" />
                                <TextBox Name="ValName" Grid.Column="5" Height="24" Margin="6,0,10,0" MinWidth="100" IsReadOnly="True" />
                                <TextBlock Name="LblGenderSummary" Grid.Column="6" VerticalAlignment="Center" Foreground="Blue" />
                                <TextBox Name="ValGender" Grid.Column="7" Height="24" Margin="6,0,0,0" MinWidth="80" IsReadOnly="True" />
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="LblSurnameProperField" Grid.Column="0" VerticalAlignment="Center" Foreground="Red" Text="c_surname_proper" />
                                <TextBox Name="ValSurnameProper" Grid.Column="1" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                                <TextBlock Name="LblMingziProperField" Grid.Column="2" VerticalAlignment="Center" Foreground="Red" Text="c_mingzi_proper" />
                                <TextBox Name="ValMingziProper" Grid.Column="3" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                                <TextBlock Name="LblNameProperField" Grid.Column="4" VerticalAlignment="Center" Foreground="Red" Text="c_name_proper" />
                                <TextBox Name="ValNameProper" Grid.Column="5" Height="24" Margin="6,0,10,0" MinWidth="100" IsReadOnly="True" />
                                <TextBlock Name="LblBirthYearSummary" Grid.Column="6" VerticalAlignment="Center" Foreground="Blue" />
                                <TextBox Name="ValBirthYear" Grid.Column="7" Height="24" Margin="6,0,0,0" MinWidth="70" IsReadOnly="True" />
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="LblSurnameRmField" Grid.Column="0" VerticalAlignment="Center" Foreground="Red" Text="c_surname_rm" />
                                <TextBox Name="ValSurnameRm" Grid.Column="1" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                                <TextBlock Name="LblMingziRmField" Grid.Column="2" VerticalAlignment="Center" Foreground="Red" Text="c_mingzi_rm" />
                                <TextBox Name="ValMingziRm" Grid.Column="3" Height="24" Margin="6,0,10,0" MinWidth="80" IsReadOnly="True" />
                                <TextBlock Name="LblNameRmField" Grid.Column="4" VerticalAlignment="Center" Foreground="Red" Text="c_name_rm" />
                                <TextBox Name="ValNameRm" Grid.Column="5" Height="24" Margin="6,0,10,0" MinWidth="100" IsReadOnly="True" />
                                <TextBlock Name="LblDeathYearSummary" Grid.Column="6" VerticalAlignment="Center" Foreground="Blue" />
                                <TextBox Name="ValDeathYear" Grid.Column="7" Height="24" Margin="6,0,0,0" MinWidth="90" IsReadOnly="True" />
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="LblDynastySummary" Grid.Column="0" VerticalAlignment="Center" />
                                <TextBox Name="ValDynasty" Grid.Column="1" Height="24" Margin="6,0,0,0" IsReadOnly="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Hidden" />
                            </Grid>

                            <Grid Grid.Row="5" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="0.8*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.4*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="LblIndexYearSummary" Grid.Column="0" VerticalAlignment="Center" />
                                <TextBox Name="ValIndexYear" Grid.Column="1" Height="24" Margin="6,0,10,0" IsReadOnly="True" />
                                <TextBlock Name="LblIndexYearTypeSummary" Grid.Column="2" VerticalAlignment="Center" />
                                <TextBox Name="ValIndexYearType" Grid.Column="3" Height="24" Margin="6,0,10,0" IsReadOnly="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Hidden" />
                                <TextBlock Name="LblIndexYearSourceSummary" Grid.Column="4" VerticalAlignment="Center" />
                                <TextBox Name="ValIndexYearSource" Grid.Column="5" Height="24" Margin="6,0,0,0" IsReadOnly="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Hidden" />
                            </Grid>

                            <Grid Grid.Row="6" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="LblIndexAddressSummary" Grid.Column="0" VerticalAlignment="Center" />
                                <TextBox Name="ValIndexAddress" Grid.Column="1" Height="24" Margin="6,0,10,0" IsReadOnly="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Hidden" />
                                <TextBlock Name="LblIndexAddressTypeSummary" Grid.Column="2" VerticalAlignment="Center" />
                                <TextBox Name="ValIndexAddressType" Grid.Column="3" Height="24" Margin="6,0,0,0" IsReadOnly="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Hidden" />
                            </Grid>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <TabControl Name="TabsDetail"
                                    SelectionChanged="TabsDetail_SelectionChanged">
                        <TabItem Name="TabBirthDeath" Header="Basic Information">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <TextBlock Name="LblAllFieldsHeader" FontSize="16" FontWeight="Bold" Foreground="#333" Text="All BIOG_MAIN Fields" />
                                    <ItemsControl Name="ItemsBasicFields" Margin="0,10,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="330" Margin="0,0,10,10" Padding="8" BorderBrush="#CFCFCF" BorderThickness="1" Background="#FAFAFA">
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold" Foreground="#4A4A4A" Text="{Binding FieldName}" />
                                                        <TextBox Margin="0,6,0,0"
                                                                 MinHeight="26"
                                                                 IsReadOnly="True"
                                                                 TextWrapping="NoWrap"
                                                                 AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                                                 Text="{Binding Value}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Name="TabAddresses" Header="Addresses">
                            <DataGrid Name="GridAddresses" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabAltNames" Header="Alt. Names">
                            <DataGrid Name="GridAltNames" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabWritings" Header="Writings">
                            <DataGrid Name="GridWritings" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabPostings" Header="Postings">
                            <DataGrid Name="GridPostings" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabEntry" Header="Entry">
                            <DataGrid Name="GridEntry" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabEvents" Header="Events">
                            <DataGrid Name="GridEvents" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabStatus" Header="Status">
                            <DataGrid Name="GridStatus" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabKinship" Header="Kinship">
                            <DataGrid Name="GridKinship" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabAssociations" Header="Associations">
                            <DataGrid Name="GridAssociations" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabPossessions" Header="Possessions">
                            <DataGrid Name="GridPossessions" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabSources" Header="Sources">
                            <DataGrid Name="GridSources" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Name="TabInstitutions" Header="Institutions">
                            <DataGrid Name="GridInstitutions" AutoGenerateColumns="True" IsReadOnly="True" AutoGeneratingColumn="RelatedGrid_AutoGeneratingColumn" CanUserAddRows="False" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </TabItem>
                        </TabControl>

                        <Border Name="PanelRelatedLoading"
                                Visibility="Collapsed"
                                Background="#80FFFFFF"
                                BorderBrush="#A9A9A9"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Panel.ZIndex="10">
                            <StackPanel Width="220">
                                <TextBlock Name="TxtRelatedLoading"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"
                                           FontWeight="SemiBold"
                                           Foreground="#333"
                                           Text="Loading details..." />
                                <ProgressBar IsIndeterminate="True" Height="16" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Name="TxtFooter" Margin="0,8,0,0" Foreground="#333" TextWrapping="NoWrap" Text="Ready" />
    </Grid>
</Window>
















