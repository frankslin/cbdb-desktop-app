<Window x:Class="Cbdb.App.Desktop.Browser.PersonBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CBDB Browser"
        Height="760"
        Width="1220"
        MinHeight="680"
        MinWidth="1060"
        Background="#E9E9E9">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Name="BtnSearch" Width="92" Height="30" Margin="0,0,8,0" Click="BtnSearch_Click" Content="Search" />
            <TextBox Grid.Column="1" Name="TxtKeyword" Height="30" Margin="0,0,8,0" VerticalContentAlignment="Center" />
            <Button Grid.Column="2" Name="BtnClear" Width="90" Height="30" Margin="0,0,8,0" Click="BtnClear_Click" Content="Clear" />
            <TextBlock Grid.Column="3" Name="LblSearchByName" VerticalAlignment="Center" FontWeight="SemiBold" />
            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="BtnLangZhHant" Width="54" Height="28" Margin="0,0,6,0" Content="繁" IsEnabled="False" />
                <Button Name="BtnLangZhHans" Width="54" Height="28" Margin="0,0,6,0" Content="简" IsEnabled="False" />
                <Button Name="BtnLangEn" Width="54" Height="28" Content="EN" IsEnabled="False" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#B7B7B7" BorderThickness="1" Background="White" Padding="6" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid Name="GridPeople"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="GridPeople_SelectionChanged"
                              LoadingRow="GridPeople_LoadingRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ColPersonId" Header="ID" Binding="{Binding PersonId}" Width="70" />
                            <DataGridTextColumn x:Name="ColName" Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn x:Name="ColNameChn" Header="中文名" Binding="{Binding NameChn}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <Button Name="BtnSaveToFile" Height="30" Content="Save to File" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="#B7B7B7" BorderThickness="1" Background="#EFEFEF" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Name="LblPersonId" Margin="0,4,6,0" />
                        <TextBox Grid.Column="1" Name="ValPersonId" Height="24" IsReadOnly="True" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="2" Name="LblGender" Margin="0,4,6,0" />
                        <TextBox Grid.Column="3" Name="ValGender" Height="24" IsReadOnly="True" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="4" Name="LblIndexYear" Margin="0,4,6,0" />
                        <TextBox Grid.Column="5" Name="ValIndexYear" Height="24" IsReadOnly="True" Margin="0,0,8,0" />
                        <TextBox Grid.Column="6" Name="TxtNotes" Height="24" IsReadOnly="True" />
                    </Grid>

                    <TabControl Grid.Row="1" Name="TabsDetail" Margin="0,8,0,0" SelectionChanged="TabsDetail_SelectionChanged">
                        <TabItem Name="TabBirthDeath" Header="Birth/Death">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Name="LblName" Grid.Row="0" />
                                    <TextBlock Name="ValName" Grid.Row="0" Grid.Column="1" />
                                    <TextBlock Name="LblNameChn" Grid.Row="1" />
                                    <TextBlock Name="ValNameChn" Grid.Row="1" Grid.Column="1" />
                                    <TextBlock Name="LblDynasty" Grid.Row="2" />
                                    <TextBlock Name="ValDynasty" Grid.Row="2" Grid.Column="1" />
                                    <TextBlock Name="LblBirthDeath" Grid.Row="3" />
                                    <TextBlock Name="ValBirthDeath" Grid.Row="3" Grid.Column="1" />
                                    <TextBlock Name="LblIndexAddress" Grid.Row="4" />
                                    <TextBlock Name="ValIndexAddress" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" />

                                    <Separator Grid.Row="5" Grid.ColumnSpan="2" Margin="0,8" />

                                    <TextBlock Name="LblAltNames" Grid.Row="6" />
                                    <TextBlock Name="ValAltNames" Grid.Row="6" Grid.Column="1" />
                                    <TextBlock Name="LblKin" Grid.Row="7" />
                                    <TextBlock Name="ValKin" Grid.Row="7" Grid.Column="1" />
                                    <TextBlock Name="LblAssoc" Grid.Row="8" />
                                    <TextBlock Name="ValAssoc" Grid.Row="8" Grid.Column="1" />
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Name="TabAddresses" Header="Addresses">
                            <DataGrid Name="GridAddresses" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Primary" Binding="{Binding Primary}" Width="1.5*" />
                                    <DataGridTextColumn Header="Secondary" Binding="{Binding Secondary}" Width="1.2*" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Name="TabAltNames" Header="Alt Names">
                            <DataGrid Name="GridAltNames" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Primary" Binding="{Binding Primary}" Width="1.5*" />
                                    <DataGridTextColumn Header="Secondary" Binding="{Binding Secondary}" Width="1.2*" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Name="TabWritings" Header="Writings">
                            <DataGrid Name="GridWritings" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Primary" Binding="{Binding Primary}" Width="1.5*" />
                                    <DataGridTextColumn Header="Secondary" Binding="{Binding Secondary}" Width="1.2*" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Name="TabPostings" Header="Postings">
                            <DataGrid Name="GridPostings" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Primary" Binding="{Binding Primary}" Width="1.5*" />
                                    <DataGridTextColumn Header="Secondary" Binding="{Binding Secondary}" Width="1.2*" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Name="TabEntry" Header="Entry">
                            <DataGrid Name="GridEntry" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Primary" Binding="{Binding Primary}" Width="1.5*" />
                                    <DataGridTextColumn Header="Secondary" Binding="{Binding Secondary}" Width="1.2*" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Name="TabEvents" Header="Events">
                            <DataGrid Name="GridEvents" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Primary" Binding="{Binding Primary}" Width="1.5*" />
                                    <DataGridTextColumn Header="Secondary" Binding="{Binding Secondary}" Width="1.2*" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Name="TabStatus" Header="Status">
                            <DataGrid Name="GridStatus" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Primary" Binding="{Binding Primary}" Width="1.5*" />
                                    <DataGridTextColumn Header="Secondary" Binding="{Binding Secondary}" Width="1.2*" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Name="TabKinship" Header="Kinship">
                            <DataGrid Name="GridKinship" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Primary" Binding="{Binding Primary}" Width="1.5*" />
                                    <DataGridTextColumn Header="Secondary" Binding="{Binding Secondary}" Width="1.2*" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Name="TabAssociations" Header="Associations">
                            <DataGrid Name="GridAssociations" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Primary" Binding="{Binding Primary}" Width="1.5*" />
                                    <DataGridTextColumn Header="Secondary" Binding="{Binding Secondary}" Width="1.2*" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Name="TxtFooter" Margin="0,10,0,0" Foreground="#444" TextWrapping="Wrap" Text="Ready" />
    </Grid>
</Window>
