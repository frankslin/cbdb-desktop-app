<Window x:Class="Cbdb.App.Desktop.Browser.PersonBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Person Browser"
        Height="760"
        Width="1160"
        MinHeight="620"
        MinWidth="980">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Name="TxtKeyword"
                     MinHeight="32"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center" />
            <Button Grid.Column="1"
                    Name="BtnSearch"
                    Width="110"
                    Margin="0,0,8,0"
                    Click="BtnSearch_Click"
                    Content="Search" />
            <Button Grid.Column="2"
                    Name="BtnClear"
                    Width="90"
                    Click="BtnClear_Click"
                    Content="Clear" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="1.7*" />
            </Grid.ColumnDefinitions>

            <DataGrid Name="GridPeople"
                      Grid.Column="0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="GridPeople_SelectionChanged"
                      Margin="0,0,8,0">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColPersonId" Header="ID" Binding="{Binding PersonId}" Width="90" />
                    <DataGridTextColumn x:Name="ColName" Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn x:Name="ColNameChn" Header="中文名" Binding="{Binding NameChn}" Width="*" />
                    <DataGridTextColumn x:Name="ColIndexYear" Header="Index Year" Binding="{Binding IndexYear}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <TabControl Grid.Column="1" Name="TabsDetail" Margin="8,0,0,0">
                <TabItem Name="TabBasic" Header="Basic">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Name="LblPersonId" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Person ID" />
                        <TextBlock Name="ValPersonId" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" />

                        <TextBlock Name="LblName" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Name" />
                        <TextBlock Name="ValName" Grid.Row="1" Grid.Column="1" />

                        <TextBlock Name="LblNameChn" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Chinese Name" />
                        <TextBlock Name="ValNameChn" Grid.Row="2" Grid.Column="1" />

                        <TextBlock Name="LblDynasty" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Dynasty" />
                        <TextBlock Name="ValDynasty" Grid.Row="3" Grid.Column="1" />

                        <TextBlock Name="LblIndexYear" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Index Year" />
                        <TextBlock Name="ValIndexYear" Grid.Row="4" Grid.Column="1" />

                        <TextBlock Name="LblBirthDeath" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Birth / Death" />
                        <TextBlock Name="ValBirthDeath" Grid.Row="5" Grid.Column="1" />

                        <TextBlock Name="LblGender" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Gender" />
                        <TextBlock Name="ValGender" Grid.Row="6" Grid.Column="1" />

                        <TextBlock Name="LblIndexAddress" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Index Address" />
                        <TextBlock Name="ValIndexAddress" Grid.Row="7" Grid.Column="1" TextWrapping="Wrap" />
                    </Grid>
                </TabItem>

                <TabItem Name="TabStats" Header="Counts">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Name="LblAltNames" Grid.Row="0" Grid.Column="0" Text="Alt Names" />
                        <TextBlock Name="ValAltNames" Grid.Row="0" Grid.Column="1" />
                        <TextBlock Name="LblKin" Grid.Row="1" Grid.Column="0" Text="Kinship" />
                        <TextBlock Name="ValKin" Grid.Row="1" Grid.Column="1" />
                        <TextBlock Name="LblAssoc" Grid.Row="2" Grid.Column="0" Text="Associations" />
                        <TextBlock Name="ValAssoc" Grid.Row="2" Grid.Column="1" />
                        <TextBlock Name="LblOffice" Grid.Row="3" Grid.Column="0" Text="Offices" />
                        <TextBlock Name="ValOffice" Grid.Row="3" Grid.Column="1" />
                        <TextBlock Name="LblEntry" Grid.Row="4" Grid.Column="0" Text="Entries" />
                        <TextBlock Name="ValEntry" Grid.Row="4" Grid.Column="1" />
                        <TextBlock Name="LblStatus" Grid.Row="5" Grid.Column="0" Text="Status" />
                        <TextBlock Name="ValStatus" Grid.Row="5" Grid.Column="1" />
                        <TextBlock Name="LblTexts" Grid.Row="6" Grid.Column="0" Text="Texts" />
                        <TextBlock Name="ValTexts" Grid.Row="6" Grid.Column="1" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <TextBlock Grid.Row="2"
                   Name="TxtFooter"
                   Margin="0,10,0,0"
                   Foreground="#444"
                   TextWrapping="Wrap"
                   Text="Ready" />
    </Grid>
</Window>

